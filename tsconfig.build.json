{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "bin/**/*.ts",
    "scripts/**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "examples",
    "test"
  ]
}
