    "build-apk": "npm run bundle-server && npx expo run:android --variant release"
  },
  "dependencies": {
    "@qvac/sdk": "^0.13.5",
    "bare-pack": "^2.1.3",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bare-kit": "^0.14.5",
    "react-native-webview": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
