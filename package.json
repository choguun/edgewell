{
  "name": "edgewell",
  "version": "3.0.1",
  "description": "EdgeWell - private on-device health and finance coach powered by QVAC — multi-agent + tool calling + P2P + multimodal",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "edgewell": "dist/bin/edgewell.js"
  },
  "scripts": {
    "start": "node --import tsx/esm bin/edgewell.js",
    "dev": "tsx bin/edgewell.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "test": "node --import tsx --test test/*.test.ts",
    "test:js": "node --test test/*.test.js"
  },
  "keywords": ["qvac", "edge", "ai", "health", "finance", "coach", "hackathon", "showcase", "multi-agent", "p2p", "tool-calling", "rag"],
  "license": "MIT",
  "engines": {
    "node": ">=22.17"
  },
  "dependencies": {
    "@qvac/sdk": "link:./vendor/qvac-sdk"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@11.6.0"
}
