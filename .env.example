# EdgeWell — example environment variables.
# Copy to `.env` and uncomment / edit the keys you want to override.
# Every key is optional; the defaults in `src/config.ts` work out of the box.

# --- Data location ---
# Override the data directory (relative or absolute path; validated against
# system roots when run as root).
# EDGEWELL_DATA_DIR=./data

# --- Local model ---
# Default: LLAMA_3_2_1B_INST_Q4_0  (1B, phone-class)
# EDGEWELL_MODEL=LLAMA_3_2_1B_INST_Q4_0

# --- Peer / delegate model (used by DelegatingLLM when P2P is enabled) ---
# Default: LLAMA_3_1_8B_INST_Q4_K_M  (8B, desktop-class)
# EDGEWELL_DELEGATE_MODEL=LLAMA_3_1_8B_INST_Q4_K_M

# --- P2P / peer client ---
# EDGEWELL_P2P_HOST=127.0.0.1
# EDGEWELL_P2P_PORT=8787
# Set to 1 to enable peer-first delegation with local fallback.
# EDGEWELL_P2P_ENABLED=1

# --- Logging ---
# One of: debug, info, warn, error
# EDGEWELL_LOG=info

# --- Plugins ---
# Directory scanned for *.plugin.js at startup.
# EDGEWELL_PLUGINS=./plugins

# --- Companion server ---
# Override the companion HMAC secret (use `edgewell rotate-secret` to mint
# a fresh one). When unset, a random per-start secret is generated.
# EDGEWELL_COMPANION_SECRET=

# --- Offline stub ---
# Set to 1 to force the `ask` command to use the in-process stub
# instead of trying to load the real @qvac/sdk. Useful for judges
# and CI.
# EDGEWELL_OFFLINE=0

# --- RAG encryption (optional, v2.0.0+) ---
# Set to 1 to encrypt the RAG chunks.json file at rest.
# EDGEWELL_RAG_ENCRYPTED=0
